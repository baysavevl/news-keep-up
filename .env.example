GEMINI_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional production DB. If unset, local SQLite is used.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Optional local DB override.
DB_PATH=data/news-keep-up.db

# Optional model and cost controls.
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_FALLBACK_MODEL=gemini-2.5-flash
MAX_LLM_ITEMS_PER_RUN=20
MAX_LLM_CALLS_PER_DAY=40
MAX_CANDIDATES_PER_SOURCE=10
MIN_RELEVANCE_SCORE=65
BACKFILL_LOOKBACK_DAYS=7
